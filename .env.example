# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Database
DATABASE_URI=sqlite:///blog.db

# Server
HOST=127.0.0.1
PORT=5000

# AI 对话（OpenAI 兼容协议）
# 设置 AI_ENABLED=true 且填写 AI_API_KEY 后启用真实大模型调用
# 未配置时自动进入演示模式（返回占位回复）
AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo
AI_SYSTEM_PROMPT=你是一个友善的博客助手，擅长阅读文章、回答问题、总结要点、翻译与改写。
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.7
AI_TIMEOUT=30